{
  "name": "partsindex",
  "private": true,
  "version": "1.12.0",
  "type": "module",
  "description": "Parts pricing reference for SG motor third-party claims \u2014 fuzzy-matched median benchmark from supplier bills.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "VITE_BASE=/partsindex/ vite build && gh-pages -d dist",
    "eval:pairs": "node eval/generate_pairs.mjs",
    "eval:score": "node eval/evaluate.mjs",
    "ocr:batch": "node tools/batch-ocr.mjs",
    "test:tools": "node tools/selftest.mjs",
    "db:init": "node tools/db-init.mjs",
    "db:seed": "node tools/db-init.mjs --seed"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.1.1",
    "vite": "^5.4.0"
  }
}